{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --proxy-config proxy.conf.json",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/animations": "^21.2.2",
    "@angular/cdk": "21.2.2",
    "@angular/common": "21.2.2",
    "@angular/compiler": "21.2.2",
    "@angular/core": "21.2.2",
    "@angular/forms": "21.2.2",
    "@angular/material": "21.2.2",
    "@angular/platform-browser": "21.2.2",
    "@angular/router": "21.2.2",
    "@stomp/stompjs": "^7.3.0",
    "rxjs": "~7.8.0",
    "sockjs-client": "^1.6.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "21.2.2",
    "@angular/cli": "21.2.2",
    "@angular/compiler-cli": "21.2.2",
    "@types/sockjs-client": "^1.5.4",
    "autoprefixer": "^10.4.16",
    "jsdom": "^27.1.0",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.4.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
